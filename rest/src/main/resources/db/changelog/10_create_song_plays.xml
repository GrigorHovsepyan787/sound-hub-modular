<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="10" author="apoghosyan">
        <createTable tableName="song_plays">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="song_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="played_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="song_plays"
                baseColumnNames="song_id"
                constraintName="fk_song_plays_song"
                referencedTableName="song"
                referencedColumnNames="id"/>

        <createIndex tableName="song_plays" indexName="idx_song_plays_song_date">
            <column name="song_id"/>
            <column name="played_at"/>
        </createIndex>

        <createIndex tableName="song_plays" indexName="idx_song_plays_played_at">
            <column name="played_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>