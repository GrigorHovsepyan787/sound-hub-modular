<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="4" author="apoghosyan">
        <createTable tableName="album">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints unique="true" primaryKey="true"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="release_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="picture_url" type="VARCHAR(255)"/>
            <column name="artist_id" type="bigint"/>
            <column name="band_id" type="bigint"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="album"
                baseColumnNames="artist_id"
                constraintName="fk_album_artist"
                referencedTableName="artist"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                baseTableName="album"
                baseColumnNames="band_id"
                constraintName="fk_album_band"
                referencedTableName="band"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>