<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2" author="apoghosyan">
        <createTable tableName="artist">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints unique="true" primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="surname" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="bio" type="TEXT"/>
            <column name="picture_name" type="VARCHAR(255)"/>
            <column name="nickname" type="VARCHAR(255)"/>
            <column name="birthdate" type="DATE"/>
            <column name="band_id" type="bigint"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="artist"
                baseColumnNames="band_id"
                constraintName="fk_artist_band"
                referencedTableName="band"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>