<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="5" author="apoghosyan">
        <createTable tableName="song">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints unique="true" primaryKey="true"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="genre" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="duration" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="play_count" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="upload_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="song_url" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="artist_id" type="bigint"/>
            <column name="band_id" type="bigint"/>
            <column name="album_id" type="bigint"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="song"
                baseColumnNames="artist_id"
                constraintName="fk_song_artist"
                referencedTableName="artist"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                baseTableName="song"
                baseColumnNames="band_id"
                constraintName="fk_song_band"
                referencedTableName="band"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                baseTableName="song"
                baseColumnNames="album_id"
                constraintName="fk_song_album"
                referencedTableName="album"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>